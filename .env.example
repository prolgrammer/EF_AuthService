## --- Service ---
AUTH_ENV=dev                       # dev | staging | prod
AUTH_LOG_LEVEL=info                # debug | info | warn | error
AUTH_INSTANCE_ID=                  # optional, autogenerated if empty

## --- HTTP / gRPC ---
AUTH_HTTP_ADDR=:8080
AUTH_GRPC_ADDR=:9090
AUTH_HTTP_READ_TIMEOUT=10s
AUTH_HTTP_WRITE_TIMEOUT=15s
AUTH_SHUTDOWN_TIMEOUT=30s

## --- PostgreSQL ---
AUTH_DB_DSN=postgres://auth:auth@localhost:5432/auth?sslmode=disable
AUTH_DB_MAX_CONNS=20
AUTH_DB_MIN_CONNS=2
AUTH_DB_MIGRATE_ON_START=true

## --- JWT ---
AUTH_JWT_ISSUER=eventflow-auth
AUTH_JWT_ACCESS_TTL=15m
AUTH_JWT_REFRESH_TTL=720h          # 30 days
AUTH_JWT_KEY_DIR=./keys            # каталог с rsa-ключами
AUTH_JWT_KEY_ROTATE_EVERY=720h     # период ротации ключей подписи
AUTH_JWT_KEY_OVERLAP=72h           # сколько держим старый ключ для валидации

## --- Observability ---
AUTH_METRICS_ADDR=:2112
AUTH_TRACING_ENABLED=false
AUTH_OTLP_ENDPOINT=otel-collector:4317
